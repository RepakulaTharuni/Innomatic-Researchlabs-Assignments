# IMPORTS
from langchain_community.llms import HuggingFacePipeline
from transformers import pipeline

from langchain.prompts import PromptTemplate
from langchain.schema.output_parser import StrOutputParser

from langchain.memory import ConversationBufferMemory
from langchain.chains import ConversationChain

from langchain.tools import tool

# LOAD MODEL 
pipe = pipeline("text-generation", model="gpt2")

llm = HuggingFacePipeline(pipeline=pipe)

# 1. LLM CALL
print("----- LLM Call -----")
print(llm.invoke("Explain LangChain in simple terms"))

# 2. PROMPT TEMPLATE
print("\n----- Prompt Template -----")

prompt = PromptTemplate(
    input_variables=["topic"],
    template="Explain {topic} in simple terms"
)

print(prompt.format(topic="Artificial Intelligence"))

# 3. CHAIN (Prompt → LLM → Output)
print("\n----- Chain -----")

chain = prompt | llm | StrOutputParser()
print(chain.invoke({"topic": "Machine Learning"}))

# 4. MEMORY (Conversation)
print("\n----- Memory -----")

memory = ConversationBufferMemory()

conversation = ConversationChain(
    llm=llm,
    memory=memory
)

conversation.predict(input="Hi, my name is Tharuni")
print(conversation.predict(input="What is my name?"))

# 5. TOOL
print("\n----- Tool -----")

@tool
def calculator(expression: str):
    """Performs math calculations"""
    return str(eval(expression))

print(calculator.run("45 * 10"))


# DONE
print("\n✅ LangChain workflow executed successfully!")
