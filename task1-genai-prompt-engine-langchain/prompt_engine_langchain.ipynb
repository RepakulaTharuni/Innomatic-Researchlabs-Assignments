from langchain_core.prompts import PromptTemplate
from langchain_core.prompts import ChatPromptTemplate


# TASK 1: Replace Hardcoded Prompt
template_1 = PromptTemplate(
    input_variables=["topic"],
    template="Explain {topic} in simple terms for beginners"
)

print("Task 1 Output:")
print(template_1.format(topic="Artificial Intelligence"))
print("\n")


# TASK 2: Multi-Input Prompt System
multi_input_template = PromptTemplate(
    input_variables=["topic", "audience", "tone"],
    template="Explain {topic} for {audience} in a {tone} tone"
)

print("Task 2 Outputs:")
print(multi_input_template.format(topic="AI", audience="beginners", tone="friendly"))
print(multi_input_template.format(topic="Python", audience="kids", tone="fun"))
print(multi_input_template.format(topic="Deep Learning", audience="engineers", tone="technical"))
print("\n")


# TASK 3: Prompt Variations Engine
teaching_template = PromptTemplate(
    input_variables=["topic"],
    template="Explain {topic} clearly step by step"
)

interview_template = PromptTemplate(
    input_variables=["topic"],
    template="Ask 3 interview questions about {topic}"
)

story_template = PromptTemplate(
    input_variables=["topic"],
    template="Explain {topic} as a story"
)

topic = "Machine Learning"

print("Task 3 Outputs:")
print(teaching_template.format(topic=topic))
print(interview_template.format(topic=topic))
print(story_template.format(topic=topic))
print("\n")


# TASK 4: ChatPromptTemplate System 
def get_chat_prompt(role, topic):

    if role == "teacher":
        system_msg = "You are a helpful teacher."
    elif role == "interviewer":
        system_msg = "You are an interviewer asking questions."
    elif role == "motivator":
        system_msg = "You are a motivational speaker."
    else:
        system_msg = "You are a helpful assistant."

    chat_template = ChatPromptTemplate.from_messages([
        ("system", system_msg),
        ("user", "Talk about {topic}")
    ])

    return chat_template.format_messages(topic=topic)


print("Task 4 Output:")
messages = get_chat_prompt("teacher", "Neural Networks")

# Cleaner display
for msg in messages:
    print(msg.type.upper() + ":", msg.content)

print("\n")


# TASK 5: Input Validation Layer 
def validate_inputs(audience, tone):

    valid_audience = ["beginners", "intermediate", "expert"]
    valid_tone = ["formal", "casual", "fun"]

    if audience not in valid_audience:
        print("Invalid audience → Defaulting to 'beginners'")
        audience = "beginners"

    if tone not in valid_tone:
        print("Invalid tone → Defaulting to 'formal'")
        tone = "formal"

    return audience, tone


print("Task 5 Output:")
audience, tone = validate_inputs("kids", "cool")
print("Validated:", audience, tone)
print("\n")


# TASK 6: Prompt Generator App 
def generate_prompt(topic, audience, tone, style):

    # Step 1: Validate Inputs
    audience, tone = validate_inputs(audience, tone)

    # Step 2: Define Templates
    if style == "teaching":
        template = PromptTemplate(
            input_variables=["topic", "audience", "tone"],
            template="Explain {topic} for {audience} in a {tone} teaching style"
        )

    elif style == "interview":
        template = PromptTemplate(
            input_variables=["topic"],
            template="Ask 3 interview questions about {topic}"
        )

    elif style == "storytelling":
        template = PromptTemplate(
            input_variables=["topic", "audience", "tone"],
            template="Explain {topic} for {audience} in a {tone} storytelling style"
        )

    else:
        return "Invalid style"

    # Step 3: Generate Prompt
    if style == "interview":
        return template.format(topic=topic)
    else:
        return template.format(topic=topic, audience=audience, tone=tone)


print("Task 6 Output:")
print(generate_prompt("Neural Networks", "beginners", "fun", "storytelling"))
print("\n")


# TASK 7: Template Reusability Test
reusable_template = PromptTemplate(
    input_variables=["topic", "audience"],
    template="Explain {topic} for {audience}"
)

test_inputs = [
    ("AI", "beginners"),
    ("Python", "students"),
    ("Data Science", "analysts"),
    ("Machine Learning", "engineers"),
    ("Deep Learning", "researchers")
]

print("Task 7 Outputs:")
for topic, audience in test_inputs:
    print(reusable_template.format(topic=topic, audience=audience))

print("\n")


# FINAL PIPELINE
def full_pipeline(topic, audience, tone, style):

    audience, tone = validate_inputs(audience, tone)
    prompt = generate_prompt(topic, audience, tone, style)

    return prompt


print("Final Pipeline Output:")
print(full_pipeline("Artificial Intelligence", "beginners", "fun", "teaching"))
