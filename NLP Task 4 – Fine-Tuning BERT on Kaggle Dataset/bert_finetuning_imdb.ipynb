# 2. Clean Setup

import warnings
warnings.filterwarnings("ignore")

import os
os.environ["TOKENIZERS_PARALLELISM"] = "false"

from transformers.utils import logging
logging.set_verbosity_error()


# 3. Imports

import pandas as pd
import numpy as np
import torch
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, precision_recall_fscore_support, confusion_matrix
from transformers import AutoTokenizer, AutoModelForSequenceClassification, Trainer, TrainingArguments

# 4. Load Dataset

df = pd.read_csv('/content/IMDB Dataset.csv', engine='python', on_bad_lines='skip')


# 5. Preprocessing

df['sentiment'] = df['sentiment'].map({'positive': 1, 'negative': 0})
df['review'] = df['review'].str.lower()
df.dropna(inplace=True)

# 🔥 Reduce size for speed
df = df.sample(2000, random_state=42)

# 6. Split Data

train_texts, temp_texts, train_labels, temp_labels = train_test_split(
    df['review'], df['sentiment'], test_size=0.2, random_state=42
)

val_texts, test_texts, val_labels, test_labels = train_test_split(
    temp_texts, temp_labels, test_size=0.5, random_state=42
)

# 7. Tokenization (FASTER)

model_name = "distilbert-base-uncased"

tokenizer = AutoTokenizer.from_pretrained(model_name)

def tokenize(texts):
    return tokenizer(list(texts), padding=True, truncation=True, max_length=64)

train_encodings = tokenize(train_texts)
val_encodings = tokenize(val_texts)
test_encodings = tokenize(test_texts)

# 8. Dataset Class

class IMDbDataset(torch.utils.data.Dataset):
    def __init__(self, encodings, labels):
        self.encodings = encodings
        self.labels = list(labels)

    def __getitem__(self, idx):
        item = {k: torch.tensor(v[idx]) for k, v in self.encodings.items()}
        item['labels'] = torch.tensor(self.labels[idx])
        return item

    def __len__(self):
        return len(self.labels)

train_dataset = IMDbDataset(train_encodings, train_labels)
val_dataset = IMDbDataset(val_encodings, val_labels)
test_dataset = IMDbDataset(test_encodings, test_labels)

# 9. Metrics

def compute_metrics(eval_pred):
    logits, labels = eval_pred
    preds = np.argmax(logits, axis=1)

    precision, recall, f1, _ = precision_recall_fscore_support(labels, preds, average='binary')
    acc = accuracy_score(labels, preds)

    return {
        'accuracy': acc,
        'precision': precision,
        'recall': recall,
        'f1': f1
    }

# 10. Training Arguments (FAST)

training_args = TrainingArguments(
    output_dir='./results',
    learning_rate=2e-5,
    per_device_train_batch_size=4,
    per_device_eval_batch_size=4,
    num_train_epochs=1,
    eval_strategy='epoch',
    save_strategy='no',
    logging_strategy='no',
    dataloader_pin_memory=False
)

# 11. FULL MODEL
model = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=2)

trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=train_dataset,
    eval_dataset=val_dataset,
    compute_metrics=compute_metrics
)

trainer.train()
results_full = trainer.evaluate(test_dataset)

print("\nFull Model:", results_full)

# Confusion Matrix
preds = np.argmax(trainer.predict(test_dataset).predictions, axis=1)
print("\nConfusion Matrix:\n", confusion_matrix(test_labels, preds))


# 12. EXPERIMENT 1: Freeze Model
model_frozen = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=2)

for param in model_frozen.base_model.parameters():
    param.requires_grad = False

trainer_frozen = Trainer(
    model=model_frozen,
    args=training_args,
    train_dataset=train_dataset,
    eval_dataset=val_dataset,
    compute_metrics=compute_metrics
)

trainer_frozen.train()
results_frozen = trainer_frozen.evaluate(test_dataset)

print("\nFrozen Model:", results_frozen)


# 13. EXPERIMENT 2: Last Layers

model_partial = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=2)

for name, param in model_partial.named_parameters():
    if "layer.4" in name or "layer.5" in name:
        param.requires_grad = True
    else:
        param.requires_grad = False

trainer_partial = Trainer(
    model=model_partial,
    args=training_args,
    train_dataset=train_dataset,
    eval_dataset=val_dataset,
    compute_metrics=compute_metrics
)

trainer_partial.train()
results_partial = trainer_partial.evaluate(test_dataset)

print("\nPartial Model:", results_partial)


# 14. FINAL COMPARISON

print("\n====== FINAL COMPARISON ======")
print("Full:", results_full)
print("Frozen:", results_frozen)
print("Partial:", results_partial)
