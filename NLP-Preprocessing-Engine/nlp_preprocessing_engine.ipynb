# IMPORT LIBRARIES

import re
import numpy as np
from collections import Counter

# TASK 2: PREPROCESS FUNCTION

def preprocess_text(text):
    try:
        if not text or text.strip() == "":
            return [], ""

        # Remove URLs & emails
        text = re.sub(r"http\S+|www\S+|https\S+", "", text)
        text = re.sub(r'\S+@\S+', '', text)

        # Remove numbers
        text = re.sub(r'\d+', '', text)

        # Lowercase
        text = text.lower()

        # Handle repeated characters (soooo → so)
        text = re.sub(r'(.)\1{2,}', r'\1', text)

        # Remove special characters & emojis
        text = re.sub(r'[^\w\s]', '', text)

        # Remove extra spaces
        text = re.sub(r'\s+', ' ', text).strip()

        tokens = text.split()

        # Remove short tokens except meaningful ones
        tokens = [word for word in tokens if len(word) > 2 or word in ["no", "not"]]

        clean_sentence = " ".join(tokens)

        return tokens, clean_sentence

    except Exception as e:
        print("Error:", e)
        return [], ""


# TASK 3: STRESS TESTING

test_sentences = [
    "Get 100% FREE access now!!!",
    "I absolutely looooved this product 😍😍",
    "Worst service ever... 0/10",
    "Call me at 9876543210",
    "This is THE best course!!!",
    "Visit https://openai.com now!",
    "Nooooo this is baaad!!!",
    "OK OK OK I got it",
    "Win $$$ now!!! Limited offer!!!",
    "I am not happy with this"
]

print("\n========== STRESS TESTING ==========\n")

results = []

for sentence in test_sentences:
    tokens, clean_sentence = preprocess_text(sentence)

    print("Original:", sentence)
    print("Tokens:", tokens)
    print("Cleaned Sentence:", clean_sentence)
    print("-" * 50)

    results.append(tokens)


# TASK 4: TOKEN ANALYTICS


print("\n========== TOKEN ANALYTICS ==========\n")

for i, tokens in enumerate(results):
    if len(tokens) == 0:
        print(f"Sentence {i+1}: No tokens")
        continue

    total_tokens = len(tokens)
    unique_tokens = len(set(tokens))
    avg_length = np.mean([len(word) for word in tokens])

    print(f"Sentence {i+1}")
    print("Total Tokens:", total_tokens)
    print("Unique Tokens:", unique_tokens)
    print("Avg Token Length:", round(avg_length, 2))
    print("-" * 40)


# ANALYSIS

print("\n========== ANALYSIS ==========\n")
print("Most noisy sentence: 'Win $$$ now!!! Limited offer!!!'")
print("Most meaningful sentence: 'I am not happy with this'")


# TASK 5: FREQUENCY ANALYSIS


print("\n========== FREQUENCY ANALYSIS ==========\n")

all_tokens = [token for sublist in results for token in sublist]

counter = Counter(all_tokens)

print("Top 10 Frequent Words:")
print(counter.most_common(10))

print("\nTop 5 Least Frequent Words:")
print(counter.most_common()[:-6:-1])


# TASK 6: FULL PIPELINE

def full_pipeline(text_list):
    all_tokens = []
    clean_sentences = []

    for text in text_list:
        tokens, clean_sentence = preprocess_text(text)
        all_tokens.extend(tokens)
        clean_sentences.append(clean_sentence)

    return {
        "tokens": all_tokens,
        "clean_sentences": clean_sentences
    }

print("\n========== FULL PIPELINE OUTPUT ==========\n")
pipeline_output = full_pipeline(test_sentences)
print(pipeline_output)


# TASK 7: ERROR HANDLING


print("\n========== EDGE CASE TESTING ==========\n")

edge_cases = [
    "",
    "😂😂😂😂",
    "1234567890"
]

for text in edge_cases:
    tokens, clean_sentence = preprocess_text(text)

    print("Input:", text)
    print("Tokens:", tokens)
    print("Cleaned Sentence:", clean_sentence)
    print("-" * 40)


