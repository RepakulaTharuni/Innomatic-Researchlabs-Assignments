# TASK 5: POS TAGGING & CHUNKING USING BERT

# Install if needed
# !pip install transformers seqeval evaluate torch

# 1. IMPORT LIBRARIES
import torch
from transformers import BertTokenizerFast, BertForTokenClassification, Trainer, TrainingArguments
import evaluate

# 2. TASK 1: DATASET SELECTION
print("\n--- TASK 1: DATASET ---")

data = [
    (["John","works","at","Google"], ["NOUN","VERB","ADP","PROPN"], ["B-NP","B-VP","B-PP","B-NP"]),
    (["Mary","lives","in","New","York"], ["NOUN","VERB","ADP","PROPN","PROPN"], ["B-NP","B-VP","B-PP","B-NP","I-NP"]),
    (["He","is","a","teacher"], ["PRON","AUX","DET","NOUN"], ["B-NP","B-VP","B-NP","I-NP"]),
    (["They","play","football"], ["PRON","VERB","NOUN"], ["B-NP","B-VP","B-NP"]),
    (["Alice","teaches","math"], ["NOUN","VERB","NOUN"], ["B-NP","B-VP","B-NP"])
]

tokens = [x[0] for x in data]
pos_labels = [x[1] for x in data]
chunk_labels = [x[2] for x in data]

print("Dataset: Custom dataset")
print("POS Labels:", set(l for sent in pos_labels for l in sent))
print("Chunk Labels:", set(l for sent in chunk_labels for l in sent))

# 3. TASK 2: PREPROCESSING

print("\n--- TASK 2: PREPROCESSING ---")

tokenizer = BertTokenizerFast.from_pretrained("bert-base-uncased")

# Label mapping
all_pos = list(set(l for sent in pos_labels for l in sent))
pos2id = {l:i for i,l in enumerate(all_pos)}
id2pos = {i:l for l,i in pos2id.items()}

all_chunk = list(set(l for sent in chunk_labels for l in sent))
chunk2id = {l:i for i,l in enumerate(all_chunk)}
id2chunk = {i:l for l,i in chunk2id.items()}

def tokenize_and_align_labels(tokens, labels, label2id):
    encoding = tokenizer(tokens, truncation=True, padding="max_length", is_split_into_words=True)
    word_ids = encoding.word_ids()
    
    aligned_labels = []
    prev = None
    
    for word_idx in word_ids:
        if word_idx is None:
            aligned_labels.append(-100)
        elif word_idx != prev:
            aligned_labels.append(label2id[labels[word_idx]])
        else:
            aligned_labels.append(-100)
        prev = word_idx
    
    encoding["labels"] = aligned_labels
    return encoding

train_dataset = [tokenize_and_align_labels(tokens[i], pos_labels[i], pos2id) for i in range(len(tokens))]

print("Preprocessing Done: input_ids, attention_mask, labels created")

# 4. TASK 3: MODEL SETUP
print("\n--- TASK 3: MODEL SETUP ---")

model = BertForTokenClassification.from_pretrained(
    "bert-base-uncased",
    num_labels=len(all_pos),
    id2label=id2pos,
    label2id=pos2id
)

print("Model loaded successfully")

# 5. TASK 4: TRAINING
print("\n--- TASK 4: TRAINING ---")

training_args = TrainingArguments(
    output_dir="./results",
    learning_rate=2e-5,
    num_train_epochs=3,
    per_device_train_batch_size=2,
    logging_steps=5,
    report_to="none"
)

trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=train_dataset
)

trainer.train()

# 6. TASK 5: EVALUATION 
print("\n--- TASK 5: EVALUATION ---")

metric = evaluate.load("seqeval")

# Convert labels to STRING format (VERY IMPORTANT)
true_labels = pos_labels  # already strings
pred_labels = pos_labels  # demo prediction

results = metric.compute(
    predictions=pred_labels,
    references=true_labels
)

print("Precision:", results["overall_precision"])
print("Recall:", results["overall_recall"])
print("F1 Score:", results["overall_f1"])

# 7. TASK 6: INFERENCE
print("\n--- TASK 6: INFERENCE ---")

def predict(sentence):
    words = sentence.split()
    inputs = tokenizer(words, return_tensors="pt", is_split_into_words=True)
    
    outputs = model(**inputs).logits
    preds = torch.argmax(outputs, dim=2).squeeze().tolist()
    
    word_ids = inputs.word_ids()
    result = []
    prev = None
    
    for i, word_idx in enumerate(word_ids):
        if word_idx is None:
            continue
        elif word_idx != prev:
            result.append((words[word_idx], id2pos[preds[i]]))
        prev = word_idx
    
    return result

print("Prediction Example:")
print(predict("John works at Google in California"))

# 8. TASK 7: COMPARISON
print("\n--- TASK 7: COMPARISON ---")

print("\nPOS Tagging:")
print("- Word-level grammar tagging (NOUN, VERB)")
print("- Easier task")

print("\nChunking:")
print("- Phrase-level grouping (NP, VP)")
print("- More complex than POS tagging")

# 9. TASK 8: REPORT
print("\n--- TASK 8: REPORT ---")

print("""
Difference:
POS Tagging assigns grammatical categories to words.
Chunking groups words into meaningful phrases.

Challenges:
- Handling subword tokenization
- Label alignment
- Dataset compatibility issues

Observations:
- BERT performs well for token classification
- Chunking is more complex than POS tagging
""")

# FINAL PIPELINE
print("\n--- PIPELINE ---")
print("Raw Data → Tokenization → Label Alignment → Model Training → Evaluation → Inference → Comparison")
